  "keyFeatures": [
    "Criação de produtos via API (curso, ebook, assinatura, software, físico)",
    "Criação de ofertas únicas e recorrentes com preset resolver (82 → 6 campos)",
    "Bearer token com escopos granulares (products:read/write, offers:read/write)",
    "Idempotency-Key obrigatório em POST para retry seguro",
    "Draft-by-default: produto criado via API não é vendável até ser ativado",
    "Isolamento de tenant por construção (404 fora do produtor autenticado)",
    "Revogação instantânea de token",
    "Ambientes sandbox e produção separados (ticto_test_ / ticto_live_)"
  ],
  "publicApiSurface": [
    "GET /api/v2/products",
    "GET /api/v2/products/{product_hash}",
    "POST /api/v2/products",
    "GET /api/v2/products/{product_hash}/offers",
    "GET /api/v2/products/{product_hash}/offers/{offer_id}",
    "POST /api/v2/products/{product_hash}/offers",
    "Authorization: Bearer ticto_live_… / ticto_test_…",
    "Idempotency-Key header (obrigatório em POST)",
    "Escopos: products:read, products:write, offers:read, offers:write"
  ]
}
